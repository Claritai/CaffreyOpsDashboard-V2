PORT=3000
NODE_ENV=production
SESSION_SECRET=replace-with-64-char-random-string

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=https://caffreyops.com/api/auth/callback

ALLOWED_USERS=sean@caffrey.com,user2@caffrey.com

INBOX_OPERATIONS=operations@caffrey.com
INBOX_EXPORT=export@caffrey.com
INBOX_IRELAND=ireland@caffrey.com
INBOX_UK=uk@caffrey.com
INBOX_EU=eu@caffrey.com
INBOX_OFFERS=offers@caffrey.com

PRIORITY_CLIENTS=maersk.com,dhl.com,kuehne-nagel.com,lidl.ie,tesco.com,dfds.com

# Hypercare overdue-load alerts (§12.4) — leave blank to disable a channel
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TEAMS_WEBHOOK_URL=your-teams-webhook-url

# Database encryption key (SQLCipher) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT lose this — without it the database cannot be opened. Back it up
# out-of-band (password manager, not in this repo).
DB_ENCRYPTION_KEY=64-hex-chars

# CSRF secret (csrf-csrf, double-submit cookie). Rotating this invalidates
# all in-flight CSRF tokens — users will hit one 403 on their next mutation
# and the frontend auto-refreshes the token.
CSRF_SECRET=64-hex-chars
