# ── Local development env (demo mode, NO real secrets) ───────────────────────
# Copy this to `backend/.env.local` and run the local stack with:
#   npm run local         (from backend/)   — boots Node serving frontend + /api
#   npm run verify:local  (from verify/)    — runs the smoke + drilldown checks
#
# This file is for running the dashboard LOCALLY in demo mode only. Demo mode and
# the test-login both bypass Microsoft Graph, so the Azure/inbox values below are
# throwaway placeholders and never contact Microsoft. Do NOT put production
# secrets here — the real .env lives only on the box and in the password manager.
#
# `.env.local` is gitignored. This `.example` is committed.

# NODE_ENV must NOT be "production" locally — that flips session cookies to
# secure-only (HTTPS) and disables the dev frontend serving in server.js.
NODE_ENV=development
PORT=3000

# Throwaway secrets — fine to be public, they only protect a local demo session.
SESSION_SECRET=local-dev-session-secret-change-me
CSRF_SECRET=local-dev-csrf-secret-change-me

# DB_ENCRYPTION_KEY must be 64 hex chars (SQLCipher raw key). This throwaway key
# encrypts a FRESH local backend/data/*.db — it is unrelated to the prod key, and
# the prod databases cannot be opened with it.
DB_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Test-login (localhost-only, token-gated) — used by the verify harness to get an
# authed demo session without Microsoft SSO. The email must be in ALLOWED_USERS.
CAFFREY_TEST_LOGIN_TOKEN=local-test-login-token
ALLOWED_USERS=dev@example.com

# Azure / Graph — placeholders only. Demo mode never calls these.
AZURE_CLIENT_ID=local-dev-unused
AZURE_TENANT_ID=local-dev-unused
AZURE_CLIENT_SECRET=local-dev-unused
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Mailbox addresses — placeholders only (live Graph mode would use the real ones).
INBOX_OPERATIONS=operations@example.com
INBOX_EXPORT=export@example.com
INBOX_IRELAND=ireland@example.com
INBOX_UK=uk@example.com
INBOX_EU=eu@example.com
INBOX_OFFERS=offers@example.com

# Notifications — leave blank locally so nothing pages out.
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
